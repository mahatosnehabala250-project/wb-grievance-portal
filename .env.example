# JWT Secret for authentication (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase PostgreSQL (Pooled connection for app queries)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxxx:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Supabase PostgreSQL (Direct connection for migrations)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.xxxxx:your-password@aws-0-ap-south-1.supabase.com:5432/postgres

# Optional: n8n Webhook URL for complaint integration
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/complaint

# Optional: Airtable API Key
# AIRTABLE_API_KEY=your-airtable-api-key
# AIRTABLE_BASE_ID=your-airtable-base-id
