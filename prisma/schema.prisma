generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// For local/sandbox development with SQLite, override in .env:
// DATABASE_URL="file:./db/custom.db"  (Prisma will auto-switch to sqlite provider)
// For production/Vercel with PostgreSQL, use the postgresql:// URL above

model User {
  id              String      @id @default(cuid())
  username        String      @unique
  passwordHash    String
  role            String      // ADMIN, BLOCK, DISTRICT, STATE
  name            String      // Display name
  block            String      // "Krishnanagar", "Nadia", "West Bengal"
  email             String?
  district        String?     // For block-level: their district
  subdivision     String?     // For block-level: their subdivision (e.g. Krishnanagar Sadar, Barasat)
  isActive        Boolean     @default(true)
  whatsappPhone   String?     // WhatsApp number for notifications (e.g. +919876543210)
  telegramChatId  String?     // Telegram chat ID for notifications
  isDistrictHead  Boolean     @default(false) // true for DISTRICT/STATE heads
  notifyVia       String      @default("both") // "whatsapp", "telegram", "both", "none"
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("users")
}

model Complaint {
  id                String        @id @default(cuid())
  ticketNo          String        @unique // e.g. WB-01001
  citizenName       String?
  phone             String?
  issue             String
  category          String        // Water Supply, Road Damage, Electricity, etc.
  village           String?       // Village or locality within block
  block             String
  subdivision       String?     // Subdivision under district (e.g. Krishnanagar Sadar)
  district          String
  urgency           String        @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status            String        @default("OPEN")  // OPEN, IN_PROGRESS, RESOLVED, REJECTED
  description       String?
  resolution        String?
  assignedToId        String?
  assignedOfficerName String?
  source              String        @default("WHATSAPP") // WHATSAPP, MANUAL, WEB
  n8nProcessed        Boolean       @default(false)
  satisfactionRating   Int?
  escalatedAt         DateTime?
  resolvedAt          DateTime?
  matchScore          Float?         // AI matching score (0-100)
  riskLevel           String?        // AI-predicted risk level
  pct                 Float?         // SLA breach percentage
  tags                String?        // JSON array stored as string
  language            String        @default("bn") // Citizen language: bn, en, hi
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  activities        ActivityLog[]
  comments          Comment[]

  @@index([district])
  @@index([block])
  @@index([status])
  @@index([urgency])
  @@index([category])
  @@index([createdAt])
  @@map("complaints")
}

model ActivityLog {
  id          String    @id @default(cuid())
  complaintId String
  action      String    // CREATED, STATUS_CHANGED, ASSIGNED, RESOLVED, REJECTED, UNASSIGNED, ESCALATED
  description String
  actorId     String?
  actorName   String?
  metadata    String?   // JSON string for extra data
  createdAt   DateTime  @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Comment {
  id          String   @id @default(cuid())
  complaintId String
  content     String
  actorId     String?
  actorName   String?
  createdAt   DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@map("comments")
}

model Feedback {
  id        String   @id @default(cuid())
  name      String
  email     String?
  message   String
  category  String   @default("General")
  rating    Int      @default(5)
  createdAt DateTime @default(now())

  @@map("feedback")
}
