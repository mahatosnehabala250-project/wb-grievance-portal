generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  passwordHash String
  role         String      // ADMIN, BLOCK, DISTRICT, STATE
  name         String      // Display name
  location     String      // "Krishnanagar", "Nadia", "West Bengal"
  district     String?     // For block-level: their district
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Complaint {
  id            String        @id @default(cuid())
  ticketNo      String        @unique // e.g. WB-01001
  citizenName   String?
  phone         String?
  issue         String
  category      String        // Water Supply, Road Damage, Electricity, etc.
  block         String
  district      String
  urgency       String        @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status        String        @default("OPEN")  // OPEN, IN_PROGRESS, RESOLVED, REJECTED
  description   String?
  resolution    String?
  assignedToId       String?
  source             String        @default("WHATSAPP") // WHATSAPP, MANUAL, WEB
  satisfactionRating Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  activities    ActivityLog[]
  comments      Comment[]
}

model ActivityLog {
  id            String   @id @default(cuid())
  complaintId   String
  action        String   // CREATED, STATUS_CHANGED, ASSIGNED, RESOLVED, REJECTED, UNASSIGNED
  description   String
  actorId       String?
  actorName     String?
  metadata      String?  // JSON string for extra data
  createdAt     DateTime @default(now())

  complaint     Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@index([createdAt])
}

model Comment {
  id           String   @id @default(uuid())
  complaintId  String
  content      String
  actorId      String?
  actorName    String?
  createdAt    DateTime @default(now())
  complaint    Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
}

model Feedback {
  id        String   @id @default(cuid())
  name      String
  email     String?
  message   String
  category  String   @default("General")
  rating    Int      @default(5)
  createdAt DateTime @default(now())
}
